# Copy to .env (which is gitignored) and fill in. Nothing here is required to run
# the hlmcp package itself — the HL public API needs no auth.

# Comma-separated 0x-prefixed wallet addresses, used only by the spike /
# data_exploration scripts (and later as sample inputs for whale tooling).
# Example: HL_SAMPLE_WALLETS=0xabc...,0xdef...
HL_SAMPLE_WALLETS=

# Runtime config overrides (read by hlmcp.config from Step 3 onward) will be
# documented here as they are introduced — e.g. HL API base URL, concurrency
# cap, rate limit, request timeout. None are wired up yet in Step 0.
