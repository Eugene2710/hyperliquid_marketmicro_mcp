# Copy to .env (which is gitignored) and fill in. Nothing here is required to run
# the hlmcp package itself — the HL public API needs no auth.

# Comma-separated 0x-prefixed wallet addresses. Used by the spike /
# data_exploration scripts, by the live integration tests
# (tests/integration/test_live_hl.py skips wallet-dependent tests when unset),
# and later as sample inputs for whale tooling.
# Example: HL_SAMPLE_WALLETS=0xabc...,0xdef...
HL_SAMPLE_WALLETS=

# Runtime config overrides read by hlmcp.config.load_config(). All optional —
# unset falls back to the spike-derived defaults encoded in HLConfig (see
# src/hlmcp/config.py and docs/architecture.md "Operating envelope").
#
# HL_BASE_URL              HL info endpoint URL          (default https://api.hyperliquid.xyz/info)
# HL_MAX_CONCURRENCY       max in-flight requests, int   (default 20)   [measured, Q5]
# HL_SUSTAINED_RATE_PER_SEC  token-bucket refill, req/s  (default 7.0)  [derived, Q4]
# HL_BURST_CAPACITY        token-bucket burst size       (default 15.0) [estimate, LOW confidence]
# HL_REQUEST_TIMEOUT_S     per-request timeout, seconds  (default 4.0)  [derived, Q3]
# HL_DEX_CACHE_TTL_S       perpDexs cache TTL, seconds   (default 300.0)
HL_BASE_URL=
HL_MAX_CONCURRENCY=
HL_SUSTAINED_RATE_PER_SEC=
HL_BURST_CAPACITY=
HL_REQUEST_TIMEOUT_S=
HL_DEX_CACHE_TTL_S=
